# Offline demo (default)
RELIABILITY_DATABASE_URL=sqlite:///data/warehouse.db
RELIABILITY_DATA_DIR=data
RELIABILITY_MODELS_DIR=data/models
RELIABILITY_OFFLINE_MODE=true

